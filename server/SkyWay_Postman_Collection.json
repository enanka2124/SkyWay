{
  "info": {
    "name": "SkyWay API",
    "description": "API collection for SkyWay Flight Booking application.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User (Multipart Form)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "firstName", "value": "Rahul", "type": "text"},
                {"key": "lastName", "value": "Sharma", "type": "text"},
                {"key": "email", "value": "rahul@example.com", "type": "text"},
                {"key": "phone", "value": "9876543210", "type": "text"},
                {"key": "password", "value": "pass123", "type": "text"},
                {"key": "address", "value": "123 MG Road", "type": "text"},
                {"key": "city", "value": "Mumbai", "type": "text"},
                {"key": "state", "value": "Maharashtra", "type": "text"},
                {"key": "pincode", "value": "400001", "type": "text"},
                {"key": "aadhaarCard", "type": "file", "description": "Select a PDF file here"}
              ]
            },
            "url": "{{base_url}}/api/auth/register"
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"rahul@example.com\",\n  \"password\": \"pass123\"\n}"
            },
            "url": "{{base_url}}/api/auth/login"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"rahul@example.com\"\n}"
            },
            "url": "{{base_url}}/api/auth/forgot-password"
          }
        },
        {
          "name": "Forgot Email (Phone Recovery)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\"\n}"
            },
            "url": "{{base_url}}/api/auth/forgot-email"
          }
        }
      ]
    },
    {
      "name": "Flights",
      "item": [
        {
          "name": "Search Flights",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/flights?from=Mumbai&to=Goa&date=2026-04-25",
              "host": ["{{base_url}}"],
              "path": ["api", "flights"],
              "query": [
                {"key": "from", "value": "Mumbai"},
                {"key": "to", "value": "Goa"},
                {"key": "date", "value": "2026-04-25"}
              ]
            }
          }
        },
        {
          "name": "Popular Routes",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/flights/popular"
          }
        }
      ]
    },
    {
      "name": "Hotels",
      "item": [
        {
          "name": "Search Hotels",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/hotels?city=Jaipur&checkin=2026-04-25&checkout=2026-04-27&guests=2",
              "host": ["{{base_url}}"],
              "path": ["api", "hotels"],
              "query": [
                {"key": "city", "value": "Jaipur"},
                {"key": "checkin", "value": "2026-04-25"},
                {"key": "checkout", "value": "2026-04-27"},
                {"key": "guests", "value": "2"}
              ]
            }
          }
        },
        {
          "name": "Get Available Cities",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/hotels/cities"
          }
        }
      ]
    },
    {
      "name": "Deals",
      "item": [
        {
          "name": "Get All Deals",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/deals"
          }
        }
      ]
    }
  ]
}
