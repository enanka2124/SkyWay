# ── SkyWay Server — Environment Variables Template ───────────────────────────
# Copy this file to .env and fill in YOUR values.
# NEVER commit .env to git. It is in .gitignore.
# Set these exact keys in Render Dashboard → Environment tab for production.
# ─────────────────────────────────────────────────────────────────────────────

PORT=5000

# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/skyway?retryWrites=true&w=majority

# JWT secret (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_here

# Your deployed frontend URL (e.g. https://skyway-client.onrender.com)
CLIENT_URL=http://localhost:5173

# Gmail credentials for sending emails
# Use an App Password (not your real password):
# Google Account → Security → 2FA → App Passwords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# RapidAPI key for flight search
SKYSCANNER_RAPIDAPI_KEY=your_rapidapi_key_here

# Fast2SMS API key for SMS OTP (optional)
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# Razorpay payment gateway keys
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
